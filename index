<script>
const g = id => document.getElementById(id);
const fmt = n => (n&&!isNaN(n)&&Number(n)>0)?'$'+Math.round(Number(n)).toLocaleString('es-MX'):'$0';
const fmtN = n => isNaN(n)||!n?0:Math.round(Number(n));
let D = {};
let areasOk = [];
let areasP3 = [];
let citas = JSON.parse(localStorage.getItem('ml_citas')||'[]');
let currentScreen = 1;

// ── PERFIL DEL ASESOR ──
function cargarPerfilGuardado(){
  const p = JSON.parse(localStorage.getItem('ml_perfil')||'{}');
  if(p.nombre){
    g('p2-display-nombre').textContent = p.nombre;
    g('p2-d-nombre').textContent = p.nombre;
    g('p2-d-especialidad').textContent = p.especialidad||'—';
    g('p2-d-experiencia').textContent = p.experiencia||'—';
    g('p2-d-cert').textContent = p.cert||'—';
    g('p2-d-zona').textContent = p.zona||'—';
    g('p2-d-tel').textContent = p.tel||'—';
    g('p2-d-email').textContent = p.email||'—';
    g('p2-e-nombre').value = p.nombre||'';
    g('p2-e-especialidad').value = p.especialidad||'';
    g('p2-e-experiencia').value = p.experiencia||'';
    g('p2-e-cert').value = p.cert||'';
    g('p2-e-zona').value = p.zona||'';
    g('p2-e-tel').value = p.tel||'';
    g('p2-e-email').value = p.email||'';
    if(p.foto){
      const img = document.createElement('img');
      img.src = p.foto;
      const ph = g('p2-photo-display');
      ph.innerHTML='';
      ph.appendChild(img);
    }
  } else {
    g('p2-display-nombre').textContent = 'Configura tu perfil';
    mostrarEdicion();
  }
}

function mostrarEdicion(){
  g('p2-display').style.display='none';
  g('p2-edit').style.display='block';
}

function guardarPerfil(){
  const p = {
    nombre: g('p2-e-nombre').value.trim(),
    especialidad: g('p2-e-especialidad').value.trim(),
    experiencia: g('p2-e-experiencia').value.trim(),
    cert: g('p2-e-cert').value.trim(),
    zona: g('p2-e-zona').value.trim(),
    tel: g('p2-e-tel').value.trim(),
    email: g('p2-e-email').value.trim(),
    foto: localStorage.getItem('ml_foto')||''
  };
  localStorage.setItem('ml_perfil', JSON.stringify(p));
  cargarPerfilGuardado();
  g('p2-display').style.display='block';
  g('p2-edit').style.display='none';
}

function cargarFoto(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    localStorage.setItem('ml_foto', e.target.result);
    const img = document.createElement('img');
    img.src = e.target.result;
    const ph = g('p2-photo-display');
    ph.innerHTML=''; ph.appendChild(img);
  };
  reader.readAsDataURL(file);
}

// ── NAVEGACIÓN PRESENTACIÓN ──
function goScreen(n){
  document.querySelectorAll('.pres-screen').forEach(s=>s.classList.remove('active'));
  const scr = g('p'+n);
  if(scr) scr.classList.add('active');
  currentScreen = n;
  window.scrollTo(0,0);
}

function selArea(key, el){
  const idx = areasP3.indexOf(key);
  if(idx>-1){
    areasP3.splice(idx,1);
    el.classList.remove('selected');
  } else {
    if(areasP3.length>=2) return;
    areasP3.push(key);
    el.classList.add('selected');
  }
  const counter = g('sel-counter');
  if(areasP3.length===0) counter.innerHTML='Selecciona <strong>1 o 2</strong> áreas';
  else if(areasP3.length===1) counter.innerHTML='<strong>1</strong> área seleccionada · Puedes elegir una más';
  else counter.innerHTML='<strong>2</strong> áreas seleccionadas';
}

function iniciarSistema(){
  // Pre-marcar las áreas seleccionadas en p3 dentro del sistema
  areasOk = areasP3.slice();
  D.areas = areasOk.slice();
  areasOk.forEach(key => {
    const el = g('ac-'+key);
    if(el){
      const colors = {
        proteccion:['#002D72','#EEF3FF'],salud:['#C0392B','#FCEBEB'],
        hijos:['#854F0B','#FAEEDA'],retiro:['#0F6E56','#EAF3DE'],
        meta:['#00999B','#E1F5EE'],fondo:['#534AB7','#EEEDFE']
      };
      el.classList.add('on');
      if(colors[key]){ el.style.borderColor=colors[key][0]; el.style.background=colors[key][1]; }
    }
  });
  document.querySelectorAll('.pres-screen').forEach(s=>s.classList.remove('active'));
  g('sistema').classList.add('active');
  window.scrollTo(0,0);
}

// ── SISTEMA ──
function switchView(v, evt){
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el=>el.classList.remove('active'));
  g('view-'+v).classList.add('active');
  if(evt) evt.target.classList.add('active');
  if(v==='historial') renderHistorial();
}

function goTo(n){
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  g('sec'+n).classList.add('active');
  for(let i=1;i<=5;i++){const el=g('pi'+i);el.className='pi'+(i<n?' done':i===n?' active':'');}
  g('slbl-top').textContent='Sección '+n+' de 5';
  window.scrollTo(0,0);
}

function pick(gid,el,val,colorClass){
  document.querySelectorAll('#'+gid+' .rb').forEach(b=>{b.classList.remove('on','red','green','gold');});
  el.classList.add('on');
  if(colorClass)el.classList.add(colorClass);
  D[gid]=val;
}

function toggleChip(el){el.classList.toggle('on');}
function getChips(gid){return[...document.querySelectorAll('#'+gid+' .chip.on')].map(c=>c.textContent).join(', ');}
function showHD(show){g('hd').style.display=show?'block':'none';}
function toggleST(show){g('st-campo').style.display=show?'block':'none';if(!show){g('f-sa-trabajo').value='';calcDiag();}}
function toggleSP(show){g('sp-campo').style.display=show?'block':'none';if(!show){g('f-sa-propio').value='';calcDiag();}}

function calcDep(){
  const str=g('f-edades').value;
  if(!str.trim()){g('f-anios-dep').value='';return;}
  const eds=str.split(',').map(e=>parseInt(e.trim())).filter(e=>!isNaN(e));
  if(!eds.length){g('f-anios-dep').value='';return;}
  const menor=Math.min(...eds);
  const anios=Math.max(0,23-menor);
  g('f-anios-dep').value=anios>0?anios+' años (hijo menor: '+menor+' años)':'Ya independientes';
  D.aniosDep=anios;
}

function calcDiag(){
  const gastos=fmtN(g('f-gastos').value);
  const ahorros=fmtN(g('f-ahorros').value);
  const saTrabajo=fmtN(g('f-sa-trabajo')?g('f-sa-trabajo').value:0);
  const saPropio=fmtN(g('f-sa-propio')?g('f-sa-propio').value:0);
  if(!gastos){g('diag-wrap').style.display='none';return;}
  const ideal=gastos*12*10;
  const minima=gastos*12*5;
  const cubierto=saTrabajo+saPropio+ahorros;
  const bIdeal=Math.max(0,ideal-cubierto);
  const bMinima=Math.max(0,minima-cubierto);
  D.gastos=gastos;D.ideal=ideal;D.minima=minima;D.cubierto=cubierto;D.bIdeal=bIdeal;D.bMinima=bMinima;D.saTrabajo=saTrabajo;D.ahorros=ahorros;
  const nombre=g('f-nombre').value.trim()||'Prospecto';
  g('d-nombre-h').textContent=nombre;
  g('d-gastos').textContent=fmt(gastos)+'/mes';
  g('d-ideal').textContent=fmt(ideal);
  g('d-minima').textContent=fmt(minima);
  g('d-st').textContent=saTrabajo>0?fmt(saTrabajo):'No tiene';
  g('d-sp').textContent=fmtN(g('f-sa-propio')?g('f-sa-propio').value:0)>0?fmt(fmtN(g('f-sa-propio').value)):'No tiene';
  g('d-ah').textContent=fmt(ahorros);
  g('d-cubierto').textContent=fmt(cubierto);
  g('d-bi').textContent=fmt(bIdeal);
  g('d-bm').textContent=fmt(bMinima);
  g('d-bi').style.color=bIdeal>1000000?'#C0392B':bIdeal>500000?'#F5A623':'#0F6E56';
  g('d-nota-st').textContent=saTrabajo>0?'* Seguro del trabajo incluido. En la 2ª cita recuerda que depende del empleo.':'';
  g('diag-wrap').style.display='block';
}

function toggleArea(key,el,color,bg){
  const idx=areasOk.indexOf(key);
  if(idx>-1){areasOk.splice(idx,1);el.classList.remove('on');el.style.borderColor='';el.style.background='';}
  else{if(areasOk.length>=2)return;areasOk.push(key);el.classList.add('on');el.style.borderColor=color;el.style.background=bg;}
  D.areas=areasOk.slice();
}

function generarWA(){
  const perfil = JSON.parse(localStorage.getItem('ml_perfil')||'{}');
  const nombre=g('f-nombre').value.trim()||'el prospecto';
  const edad=g('f-edad').value||'—';
  const asesor=perfil.nombre||g('f-tel').value.trim()||'[Asesor]';
  const tel=perfil.tel||g('f-tel').value.trim()||'[Teléfono]';
  const trabajo=D['rg-trabajo']||'—';
  const fuma=D['rg-fuma']||'No';
  const ec=D['rg-ec']||'—';
  const hijos=g('f-hijos').value||'0';
  const aniosDep=g('f-anios-dep').value||'—';
  const proveedor=D['rg-proveedor']||'—';
  const salud=D['rg-salud']||'—';
  const historial=D['rg-hist']||'—';
  const presupuesto=g('f-presupuesto').value;
  const adicional=g('f-adicional').value;
  const momento=D['rg-momento']||'';
  const pago=D['rg-pago']||'Anual';
  const segundaCita=g('f-segunda-cita').value.trim();
  const porQue=g('f-por-que').value.trim();
  const chipsCorto=getChips('cg-corto');
  const chipsMedio=getChips('cg-medio');
  const chipsLargo=getChips('cg-largo');
  const notaCorto=g('f-meta-corto').value.trim();
  const notaMedio=g('f-meta-medio').value.trim();
  const notaLargo=g('f-meta-largo').value.trim();
  const areaTextos={proteccion:'♥ Protección familiar',salud:'＋ Salud y emergencias',hijos:'✎ Futuro de hijos',retiro:'☀ Retiro',meta:'★ Meta personal',fondo:'◎ Fondo propio'};
  const metas=(D.areas||[]).map(a=>areaTextos[a]).join(' + ')||'—';
  let metasSection='';
  if(chipsCorto||notaCorto){metasSection+=`\n📌 *Corto plazo (1-5 años)*`;if(chipsCorto)metasSection+=`\n${chipsCorto}`;if(notaCorto)metasSection+=`\n_"${notaCorto}"_`;}
  if(chipsMedio||notaMedio){metasSection+=`\n\n📌 *Mediano plazo (5-10 años)*`;if(chipsMedio)metasSection+=`\n${chipsMedio}`;if(notaMedio)metasSection+=`\n_"${notaMedio}"_`;}
  if(chipsLargo||notaLargo){metasSection+=`\n\n📌 *Largo plazo (+10 años)*`;if(chipsLargo)metasSection+=`\n${chipsLargo}`;if(notaLargo)metasSection+=`\n_"${notaLargo}"_`;}
  let diagSection='';
  if(D.gastos){diagSection=`\n\n💡 *Diagnóstico de protección*\n• S.A. ideal (10 años): *${fmt(D.ideal)}*\n• S.A. mínima (5 años): *${fmt(D.minima)}*\n• Total cubierto hoy: ${fmt(D.cubierto)}\n• Brecha ideal: *${fmt(D.bIdeal)}*\n• Brecha mínima: *${fmt(D.bMinima)}*`;if(D.saTrabajo>0)diagSection+=`\n_(Incluye seguro del trabajo — recuerda que depende del empleo)_`;}
  const wa=`Hola ${nombre} 👋\n\nFue un placer platicar contigo hoy. Te comparto el resumen de nuestra conversación:\n\n👤 *Tu perfil*\n• ${edad} años · ${trabajo}${fuma==='Sí'?' · Fumador':''}\n• Estado civil: ${ec} · Hijos: ${hijos}\n• Dependientes aprox. ${aniosDep}\n• Sostén económico: ${proveedor}\n• Salud actual: ${salud}\n• Historial familiar: ${historial}${diagSection}\n\n🎯 *Lo que más te interesa lograr*\n*${metas}*${porQue?'\n\n"'+porQue+'"':''}${metasSection}\n\n📋 *Lo que voy a prepararte*\nUn Proyecto Financiero personalizado con 3 opciones:\n• Aportación base: *${fmt(presupuesto)}/${pago.toLowerCase()}*${adicional&&Number(adicional)>0?'\n• Aportación adicional: '+fmt(adicional)+' ('+momento+')':''}\n\n📅 *Tu próxima cita*\n${segundaCita||'Por confirmar — te escribo para coordinar'}\n\nCualquier duda estoy a tus órdenes. ¡Hasta pronto! 🙌\n\n_MetLife · ${asesor}_\n_${tel}_`;
  g('wa-text').textContent=wa;
  g('wa-output').style.display='block';
  window._wa=wa;
  setTimeout(()=>window.scrollTo(0,99999),100);
}

function copiarWA(){
  if(navigator.clipboard&&window._wa){navigator.clipboard.writeText(window._wa).then(()=>{const b=g('btn-copiar');b.textContent='¡Copiado ✓';setTimeout(()=>{b.textContent='Copiar mensaje';},2000);});}
}

function guardarCita(){
  const nombre=g('f-nombre').value.trim();
  if(!nombre){alert('Escribe el nombre del prospecto para guardar.');return;}
  const perfil=JSON.parse(localStorage.getItem('ml_perfil')||'{}');
  const cita={
    id:Date.now(),
    fecha:new Date().toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'numeric'}),
    nombre,asesor:perfil.nombre||'—',
    edad:g('f-edad').value||'—',trabajo:D['rg-trabajo']||'—',
    proveedor:D['rg-proveedor']||'—',salud:D['rg-salud']||'—',
    historial:D['rg-hist']||'—',ideal:D.ideal||0,minima:D.minima||0,
    bIdeal:D.bIdeal||0,bMinima:D.bMinima||0,areas:(D.areas||[]),
    presupuesto:g('f-presupuesto').value||'—',
    segundaCita:g('f-segunda-cita').value.trim()||'Por confirmar',
    obs:g('f-obs').value.trim()||''
  };
  citas.unshift(cita);
  localStorage.setItem('ml_citas',JSON.stringify(citas));
  alert('✓ Cita guardada para '+nombre);
}

function renderHistorial(){
  const list=g('hist-list');
  const empty=g('hist-empty');
  if(!citas.length){empty.style.display='block';list.innerHTML='';return;}
  empty.style.display='none';
  const areaTextos={proteccion:'Protección familiar',salud:'Salud y emergencias',hijos:'Futuro de hijos',retiro:'Retiro',meta:'Meta personal',fondo:'Fondo propio'};
  list.innerHTML=citas.map(c=>`
    <div class="hist-card">
      <div class="hist-card-header"><div class="hist-name">${c.nombre}</div><div class="hist-date">${c.fecha}</div></div>
      <div class="hist-row"><strong>Asesor:</strong> ${c.asesor} · <strong>Edad:</strong> ${c.edad} · <strong>Trabajo:</strong> ${c.trabajo}</div>
      <div class="hist-row"><strong>Sostén:</strong> ${c.proveedor} · <strong>Salud:</strong> ${c.salud}</div>
      ${c.ideal>0?`<div class="hist-row"><strong>S.A. ideal:</strong> ${fmt(c.ideal)} · <strong>S.A. mínima:</strong> ${fmt(c.minima)}</div><div class="hist-row"><strong>Brecha ideal:</strong> ${fmt(c.bIdeal)} · <strong>Brecha mínima:</strong> ${fmt(c.bMinima)}</div>`:''}
      <div class="hist-row"><strong>Interés:</strong> ${c.areas.map(a=>areaTextos[a]||a).join(' + ')||'—'}</div>
      <div class="hist-row"><strong>Presupuesto:</strong> ${fmt(c.presupuesto)}/año · <strong>2ª cita:</strong> ${c.segundaCita}</div>
      ${c.obs?`<div class="hist-row"><strong>Notas:</strong> ${c.obs}</div>`:''}
      <div style="margin-top:8px;"><button class="btn sm" onclick="eliminarCita(${c.id})" style="color:#C0392B;border-color:#C0392B;">Eliminar</button></div>
    </div>`).join('');
}

function eliminarCita(id){
  if(!confirm('¿Eliminar esta cita?'))return;
  citas=citas.filter(c=>c.id!==id);
  localStorage.setItem('ml_citas',JSON.stringify(citas));
  renderHistorial();
}

function nuevoCliente(){
  document.querySelectorAll('#sistema input[type=text],#sistema input[type=number],#sistema textarea').forEach(i=>i.value='');
  document.querySelectorAll('#sistema .rb').forEach(b=>b.classList.remove('on','red','green','gold'));
  document.querySelectorAll('#sistema .chip').forEach(c=>c.classList.remove('on'));
  document.querySelectorAll('#sistema .ac').forEach(c=>{c.classList.remove('on');c.style.borderColor='';c.style.background='';});
  g('hd').style.display='none';
  g('st-campo').style.display='none';
  g('sp-campo').style.display='none';
  g('diag-wrap').style.display='none';
  g('wa-output').style.display='none';
  areasOk=[];areasP3=[];D={};
  document.querySelectorAll('.pres-screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.area-card').forEach(c=>{c.classList.remove('selected');});
  g('sel-counter').innerHTML='Selecciona <strong>1 o 2</strong> áreas';
  g('p1').classList.add('active');
  g('sistema').classList.remove('active');
  window.scrollTo(0,0);
}

