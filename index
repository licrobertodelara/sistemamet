<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema Metalife · Primera Cita</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#F5F7FA;color:#1A1A2E;min-height:100vh;}
.app{max-width:720px;margin:0 auto;padding:1rem;}

/* ══ PRESENTACIÓN ══ */
.pres-screen{display:none;min-height:90vh;border-radius:16px;overflow:hidden;margin-bottom:1rem;position:relative;}
.pres-screen.active{display:flex;flex-direction:column;}

/* Pantalla 1 - MetLife */
.p1{background-color:#002D72 !important;background:#002D72 !important;}
.p1-logo{display:flex;align-items:center;gap:12px;padding:2rem 2rem 0;}
.p1-icon{width:52px;height:52px;background:#97C123;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#002D72;}
.p1-brand{color:#fff;}
.p1-brand-name{font-size:22px;font-weight:700;color:#ffffff !important;}
.p1-brand-sub{font-size:13px;color:rgba(255,255,255,0.7) !important;}
.p1-content{flex:1;display:flex;flex-direction:column;justify-content:center;padding:2rem;}
.p1-headline{font-size:36px;font-weight:700;color:#ffffff !important;line-height:1.2;margin-bottom:1rem;}
.p1-headline span{color:#97C123 !important;}
.p1-sub{font-size:15px;color:rgba(255,255,255,0.9) !important;margin-bottom:2rem;line-height:1.6;}
.p1-facts{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:2rem;}
.p1-fact{background:rgba(255,255,255,0.15) !important;border:1px solid rgba(255,255,255,0.2);border-radius:10px;padding:14px;}
.p1-fact-num{font-size:24px;font-weight:700;color:#97C123 !important;}
.p1-fact-label{font-size:12px;color:rgba(255,255,255,0.85) !important;margin-top:2px;}
.p1-footer{font-size:12px;color:rgba(255,255,255,0.7) !important;padding:1rem 2rem 2rem;}

/* Pantalla 2 - Asesor */
.p2{background:#fff;}
.p2-top{background:#002D72;padding:1.5rem 2rem;}
.p2-top-title{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:4px;}
.p2-top-name{font-size:24px;font-weight:700;color:#fff;}
.p2-content{padding:1.5rem 2rem;flex:1;}
.p2-photo{width:110px;height:110px;border-radius:50%;background:#E4EAF4;border:3px solid #97C123;display:flex;align-items:center;justify-content:center;font-size:13px;color:#5A6A7E;margin-bottom:1.25rem;overflow:hidden;cursor:pointer;position:relative;}
.p2-photo img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.p2-photo-hint{position:absolute;bottom:0;left:0;right:0;background:rgba(0,45,114,0.7);color:#fff;font-size:10px;text-align:center;padding:4px;border-radius:0 0 50% 50%;}
.p2-edit-mode .p2-info-display{display:none;}
.p2-edit-mode .p2-info-edit{display:block;}
.p2-info-display{display:block;}
.p2-info-edit{display:none;}
.info-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid #E4EAF4;}
.info-row:last-child{border-bottom:none;}
.info-icon{font-size:18px;flex-shrink:0;margin-top:2px;}
.info-label{font-size:11px;color:#5A6A7E;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;}
.info-val{font-size:14px;font-weight:600;color:#1A1A2E;}
.info-val.placeholder{color:#B0B8C8;font-weight:400;font-style:italic;}
.p2-edit-btn{display:inline-flex;align-items:center;gap:6px;font-size:12px;padding:7px 14px;border:1px solid #D1D9E8;border-radius:8px;cursor:pointer;background:#F5F7FA;color:#5A6A7E;margin-top:1rem;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:480px){.g2{grid-template-columns:1fr;}}
.f{display:flex;flex-direction:column;gap:4px;margin-bottom:2px;}
.f.full{grid-column:1/-1;}
label{font-size:11px;font-weight:600;color:#5A6A7E;text-transform:uppercase;letter-spacing:0.05em;}
input[type=text],input[type=number],input[type=file],textarea,select{width:100%;padding:9px 11px;border:1px solid #D1D9E8;border-radius:8px;font-size:13px;background:#fff;color:#1A1A2E;font-family:inherit;}
textarea{resize:vertical;min-height:58px;line-height:1.5;}
input:focus,textarea:focus{outline:none;border-color:#002D72;box-shadow:0 0 0 3px rgba(0,45,114,0.1);}
input[readonly]{background:#F5F7FA;color:#5A6A7E;}
.save-btn{background:#002D72;color:#fff;border:none;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;margin-top:10px;}

/* Pantalla 3 - Áreas */
.p3{background:#F5F7FA;}
.p3-top{background:#002D72;padding:1.5rem 2rem;}
.p3-top-title{font-size:22px;font-weight:700;color:#fff;margin-bottom:4px;}
.p3-top-sub{font-size:13px;color:rgba(255,255,255,0.65);}
.p3-content{padding:1rem 1rem;flex:1;}
.p3-instruccion{font-size:13px;color:#5A6A7E;margin-bottom:1rem;text-align:center;font-style:italic;}
.areas-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1rem;}
@media(max-width:480px){.areas-grid{grid-template-columns:1fr;}}
.area-card{background:#fff;border:2px solid #E4EAF4;border-radius:12px;padding:14px;cursor:pointer;transition:all 0.15s;}
.area-card.selected{border-color:var(--ac);background:var(--ab);}
.area-icon{font-size:24px;margin-bottom:8px;}
.area-title{font-size:13px;font-weight:700;color:#1A1A2E;margin-bottom:4px;}
.area-desc{font-size:12px;color:#5A6A7E;line-height:1.45;}
.area-badge{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-top:8px;padding:3px 8px;border-radius:10px;display:inline-block;}
.sel-counter{text-align:center;font-size:13px;color:#5A6A7E;margin-bottom:1rem;}
.sel-counter strong{color:#002D72;}

/* Navegación presentación */
.pres-nav{display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem;background:rgba(0,0,0,0.25) !important;}
.pres-nav.light{background:#E4EAF4;}
.pres-dots{display:flex;gap:8px;}
.dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.4) !important;}
.dot.dark{background:#C8D4E8;}
.dot.active{background:#97C123;width:24px;border-radius:4px;}
.dot.dark.active{background:#002D72;}
.pres-btn{padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none;}
.pres-btn.white{background:#fff;color:#002D72;}
.pres-btn.navy{background:#002D72;color:#fff;}
.pres-btn.lime{background:#97C123;color:#fff;}
.pres-btn.outline{background:transparent;border:2px solid #002D72;color:#002D72;}

/* ══ SISTEMA DE CITA ══ */
.sistema{display:none;}
.sistema.active{display:block;}
.topbar{display:flex;align-items:center;justify-content:space-between;background:#002D72;border-radius:12px;padding:12px 16px;margin-bottom:1rem;}
.brand{display:flex;align-items:center;gap:10px;}
.bi{width:36px;height:36px;background:#97C123;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#002D72;}
.bn{font-size:14px;font-weight:700;color:#fff;}
.bs{font-size:11px;color:rgba(255,255,255,0.6);}
.slbl{font-size:12px;color:rgba(255,255,255,0.7);}
.prog{display:flex;margin-bottom:1rem;border-radius:10px;overflow:hidden;border:1px solid #E4EAF4;}
.pi{flex:1;padding:8px 4px;text-align:center;font-size:10px;cursor:pointer;border-right:1px solid #E4EAF4;color:#5A6A7E;background:#fff;}
.pi:last-child{border-right:none;}
.pi.done{background:#EEF3FF;color:#002D72;}
.pi.active{background:#002D72;color:#fff;font-weight:600;}
.pi-n{font-size:14px;font-weight:600;display:block;margin-bottom:2px;}
.sec{display:none;}
.sec.active{display:block;}
.card{background:#fff;border-radius:12px;padding:1.25rem;margin-bottom:1rem;border:1px solid #E4EAF4;}
.st{font-size:17px;font-weight:600;color:#1A1A2E;margin-bottom:3px;}
.ss{font-size:12px;color:#5A6A7E;margin-bottom:1rem;}
.tip{border-radius:0 10px 10px 0;padding:10px 12px;font-size:12px;line-height:1.65;margin-bottom:1rem;}
.tip.blue{background:#EEF3FF;border-left:3px solid #002D72;color:#0C447C;}
.tip.green{background:#EAF3DE;border-left:3px solid #0F6E56;color:#27500A;}
.tip.gold{background:#FAEEDA;border-left:3px solid #F5A623;color:#633806;}
.tip.red{background:#FCEBEB;border-left:3px solid #C0392B;color:#791F1F;}
.tip.big{font-size:13px;line-height:1.8;}
.rg{display:flex;gap:6px;flex-wrap:wrap;}
.rb{padding:6px 12px;border:1px solid #D1D9E8;border-radius:8px;font-size:12px;cursor:pointer;color:#5A6A7E;background:#fff;white-space:nowrap;}
.rb.on{border-color:#002D72;background:#EEF3FF;color:#002D72;font-weight:600;}
.rb.on.red{border-color:#C0392B;background:#FCEBEB;color:#791F1F;}
.rb.on.green{border-color:#0F6E56;background:#EAF3DE;color:#27500A;}
.rb.on.gold{border-color:#F5A623;background:#FAEEDA;color:#633806;}
.divider{height:1px;background:#E4EAF4;margin:1rem 0;}
.sec-lbl{font-size:11px;font-weight:600;color:#5A6A7E;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;}
.sig{display:flex;align-items:flex-start;gap:8px;padding:8px 10px;background:#F5F7FA;border-radius:8px;margin-bottom:6px;font-size:12px;color:#5A6A7E;}
.sd{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.btn-row{display:flex;gap:8px;margin-top:1.25rem;flex-wrap:wrap;}
.btn{padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid #D1D9E8;background:#fff;color:#1A1A2E;}
.btn:hover{background:#F5F7FA;}
.btn.navy{background:#002D72;color:#fff;border-color:#002D72;}
.btn.lime{background:#97C123;color:#fff;border-color:#97C123;}
.btn.sm{padding:7px 14px;font-size:12px;}
.auto-b{display:inline-block;font-size:10px;padding:2px 8px;border-radius:10px;background:#EAF3DE;color:#3B6D11;font-weight:600;margin-left:6px;}
.qb{background:#F5F7FA;border-radius:10px;padding:12px 14px;margin-bottom:10px;}
.qt{font-size:13px;font-weight:600;color:#1A1A2E;margin-bottom:8px;line-height:1.5;}
.mb{border:1px solid #E4EAF4;border-radius:10px;padding:12px 14px;margin-bottom:10px;}
.mh{font-size:12px;font-weight:600;color:#5A6A7E;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.md{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;}
.chip{padding:5px 10px;border:1px solid #D1D9E8;border-radius:20px;font-size:11px;cursor:pointer;color:#5A6A7E;background:#fff;}
.chip.on{border-color:#002D72;background:#EEF3FF;color:#002D72;font-weight:600;}
.pres-block{border:1px solid #E4EAF4;border-radius:10px;padding:14px;margin-bottom:10px;}
.pres-title{font-size:13px;font-weight:600;color:#1A1A2E;margin-bottom:4px;}
.pres-sub{font-size:12px;color:#5A6A7E;margin-bottom:10px;line-height:1.5;font-style:italic;}
.diag-wrap{border:1px solid #E4EAF4;border-radius:10px;overflow:hidden;margin-bottom:12px;}
.diag-hdr{background:#002D72;color:#fff;padding:10px 14px;font-size:12px;font-weight:600;}
.diag-body{padding:12px 14px;}
.diag-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid #E4EAF4;font-size:13px;}
.diag-row:last-child{border-bottom:none;}
.diag-key{color:#5A6A7E;font-size:12px;}
.diag-val{font-weight:600;}
.brecha-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;}
.bc{border-radius:8px;padding:12px;text-align:center;}
.bc.ideal{background:#EEF3FF;border:2px solid #002D72;}
.bc.minima{background:#E6F1FB;border:1px solid #006BC8;}
.bc-lbl{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px;}
.bc-val{font-size:18px;font-weight:600;}
.bc-sub{font-size:10px;color:#5A6A7E;margin-top:2px;}
.cubierto-row{background:#F5F7FA;border-radius:8px;padding:8px 12px;display:flex;justify-content:space-between;font-size:12px;margin-top:8px;}
.nav-tabs{display:flex;gap:8px;margin-bottom:1rem;}
.nav-tab{flex:1;padding:8px;border:1px solid #D1D9E8;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;text-align:center;color:#5A6A7E;background:#fff;}
.nav-tab.active{background:#002D72;color:#fff;border-color:#002D72;}
.view{display:none;}
.view.active{display:block;}
.hist-card{background:#fff;border:1px solid #E4EAF4;border-radius:10px;padding:12px 14px;margin-bottom:8px;}
.hist-card-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.hist-name{font-size:14px;font-weight:600;color:#002D72;}
.hist-date{font-size:11px;color:#5A6A7E;}
.hist-row{font-size:12px;color:#5A6A7E;margin-bottom:3px;}
.hist-row strong{color:#1A1A2E;}
.wa-wrap{background:#075E54;border-radius:12px;padding:14px;margin-top:1rem;}
.wa-bub{background:#DCF8C6;border-radius:0 12px 12px 12px;padding:12px 14px;font-size:12px;color:#111;line-height:1.8;white-space:pre-wrap;word-break:break-word;}
.wa-t{font-size:10px;color:rgba(255,255,255,0.6);text-align:right;margin-top:6px;}
</style>
</head>
<body>
<div class="app">

<!-- ══════════════════════════════════════
     PANTALLA 1 — METLIFE
══════════════════════════════════════ -->
<div class="pres-screen active" id="p1">
  <div class="p1-logo">
    <div class="p1-icon">ML</div>
    <div class="p1-brand">
      <div class="p1-brand-name">MetLife México</div>
      <div class="p1-brand-sub">Agencia de Seguros</div>
    </div>
  </div>
  <div class="p1-content">
    <div class="p1-headline">Tu familia merece<br><span>estar protegida.</span></div>
    <div class="p1-sub">Hoy vamos a hacer algo diferente. No vine a venderte un seguro. Vine a entender tu situación y ayudarte a ver si tienes algo sin cubrir.</div>
    <div class="p1-facts">
      <div class="p1-fact"><div class="p1-fact-num">150+</div><div class="p1-fact-label">Años protegiendo familias en el mundo</div></div>
      <div class="p1-fact"><div class="p1-fact-num">No. 1</div><div class="p1-fact-label">Aseguradora de vida en México</div></div>
      <div class="p1-fact"><div class="p1-fact-num">90M+</div><div class="p1-fact-label">Clientes en más de 40 países</div></div>
      <div class="p1-fact"><div class="p1-fact-num">24/7</div><div class="p1-fact-label">Atención médica incluida en tu plan</div></div>
    </div>
  </div>
  <div class="p1-footer">Tu tranquilidad es nuestro negocio desde 1868.</div>
  <div class="pres-nav">
    <div class="pres-dots">
      <div class="dot active"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>
    <button class="pres-btn white" onclick="goScreen(2)">Siguiente →</button>
  </div>
</div>

<!-- ══════════════════════════════════════
     PANTALLA 2 — ASESOR
══════════════════════════════════════ -->
<div class="pres-screen" id="p2">
  <div class="p2-top">
    <div class="p2-top-title">Tu asesor MetLife</div>
    <div class="p2-top-name" id="p2-display-nombre">Cargando...</div>
  </div>
  <div class="p2-content" id="p2-content">

    <!-- Modo visualización -->
    <div id="p2-display">
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
        <div class="p2-photo" id="p2-photo-display">
          <span id="p2-photo-placeholder">📷<br><span style="font-size:10px;">Sin foto</span></span>
        </div>
        <div>
          <div style="font-size:18px;font-weight:700;color:#1A1A2E;" id="p2-d-nombre">—</div>
          <div style="font-size:13px;color:#5A6A7E;" id="p2-d-especialidad">—</div>
        </div>
      </div>
      <div class="p2-info-display">
        <div class="info-row"><div class="info-icon">🏆</div><div><div class="info-label">Experiencia</div><div class="info-val" id="p2-d-experiencia">—</div></div></div>
        <div class="info-row"><div class="info-icon">📜</div><div><div class="info-label">Certificaciones</div><div class="info-val" id="p2-d-cert">—</div></div></div>
        <div class="info-row"><div class="info-icon">📍</div><div><div class="info-label">Zona de atención</div><div class="info-val" id="p2-d-zona">—</div></div></div>
        <div class="info-row"><div class="info-icon">📱</div><div><div class="info-label">Contacto</div><div class="info-val" id="p2-d-tel">—</div></div></div>
        <div class="info-row"><div class="info-icon">✉️</div><div><div class="info-label">Correo</div><div class="info-val" id="p2-d-email">—</div></div></div>
      </div>
      <button class="p2-edit-btn" onclick="mostrarEdicion()">✏️ Editar mi perfil</button>
    </div>

    <!-- Modo edición -->
    <div id="p2-edit" style="display:none;">
      <div style="font-size:13px;font-weight:600;color:#002D72;margin-bottom:12px;">Completa tu perfil — se guarda automáticamente</div>
      <div class="f full" style="margin-bottom:10px;">
        <label>Foto de perfil</label>
        <input type="file" id="p2-foto-input" accept="image/*" onchange="cargarFoto(this)">
      </div>
      <div class="g2">
        <div class="f full"><label>Nombre completo</label><input type="text" id="p2-e-nombre" placeholder="Tu nombre completo"></div>
        <div class="f full"><label>Especialidad</label><input type="text" id="p2-e-especialidad" placeholder="Ej: Especialista en protección financiera"></div>
        <div class="f"><label>Años de experiencia</label><input type="text" id="p2-e-experiencia" placeholder="Ej: 8 años en MetLife"></div>
        <div class="f"><label>Zona de atención</label><input type="text" id="p2-e-zona" placeholder="Ej: Torreón, Coahuila"></div>
        <div class="f"><label>Certificaciones</label><input type="text" id="p2-e-cert" placeholder="Ej: AMIS, Agente Certificado MetLife"></div>
        <div class="f"><label>Teléfono</label><input type="text" id="p2-e-tel" placeholder="+52 871 000 0000"></div>
        <div class="f full"><label>Correo electrónico</label><input type="text" id="p2-e-email" placeholder="tucorreo@metlife.com"></div>
      </div>
      <button class="save-btn" onclick="guardarPerfil()">Guardar perfil</button>
    </div>

  </div>
  <div class="pres-nav light">
    <div class="pres-dots">
      <div class="dot dark"></div>
      <div class="dot dark active"></div>
      <div class="dot dark"></div>
    </div>
    <div style="display:flex;gap:8px;">
      <button class="pres-btn outline" onclick="goScreen(1)">← Atrás</button>
      <button class="pres-btn navy" onclick="goScreen(3)">Siguiente →</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     PANTALLA 3 — ÁREAS DE INTERÉS
══════════════════════════════════════ -->
<div class="pres-screen" id="p3">
  <div class="p3-top">
    <div class="p3-top-title">¿Qué situación te resuena más?</div>
    <div class="p3-top-sub">Señala hasta 2 áreas que más te importen hoy</div>
  </div>
  <div class="p3-content">
    <div class="p3-instruccion">Toca las que más te identifican. No hay respuestas correctas.</div>
    <div class="sel-counter" id="sel-counter">Selecciona <strong>1 o 2</strong> áreas</div>
    <div class="areas-grid">
      <div class="area-card" id="a-proteccion" style="--ac:#002D72;--ab:#EEF3FF;" onclick="selArea('proteccion',this)">
        <div class="area-icon">♥</div>
        <div class="area-title">Protección familiar</div>
        <div class="area-desc">Garantizar que tu familia mantenga su estilo de vida aunque tú ya no estés con ellos.</div>
        <div class="area-badge" style="background:#EEF3FF;color:#002D72;">Protección y legado</div>
      </div>
      <div class="area-card" id="a-salud" style="--ac:#C0392B;--ab:#FCEBEB;" onclick="selArea('salud',this)">
        <div class="area-icon">＋</div>
        <div class="area-title">Salud y emergencias</div>
        <div class="area-desc">En caso de enfermedad o accidente, atenderte en hospital privado sin preocuparte por la cuenta.</div>
        <div class="area-badge" style="background:#FCEBEB;color:#C0392B;">Salud y emergencias</div>
      </div>
      <div class="area-card" id="a-hijos" style="--ac:#854F0B;--ab:#FAEEDA;" onclick="selArea('hijos',this)">
        <div class="area-icon">✎</div>
